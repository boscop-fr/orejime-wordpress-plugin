{
  "name": "@boscop/orejime-wordpress-plugin",
  "private": true,
  "scripts": {
    "up": "wp-env start --update",
    "start": "npm run package-orejime && wp-scripts start",
    "build": "npm run package-orejime && wp-scripts build",
    "package": "npm run build && wp-scripts plugin-zip --no-root-folder",
    "package-orejime": "node scripts/package-orejime.mjs",
    "lint": "npm run lint-js && npm run lint-php && npm run lint-plugin",
    "lint-js": "wp-scripts lint-js ./src ./scripts/*",
    "lint-php": "npm run composer lint",
    "lint-plugin": "wp-env run cli wp plugin check wp-content/plugins/orejime-wordpress-plugin --require=./wp-content/plugins/plugin-check/cli.php --require=./wp-content/plugins/orejime-wordpress-plugin/tests/pcp.php --slug=orejime",
    "format": "npm run format-js && npm run format-php",
    "format-js": "wp-scripts format ./src ./scripts/*",
    "format-php": "npm run composer format",
    "test": "npm run test-php",
    "test-php": "wp-env run cli --env-cwd=wp-content/plugins/orejime-wordpress-plugin ./vendor/bin/phpunit",
    "composer": "wp-env run cli --env-cwd=wp-content/plugins/orejime-wordpress-plugin composer"
  },
  "files": [
    "build",
    "includes",
    "public",
    "LICENSE",
    "orejime.php",
    "readme.txt"
  ],
  "devDependencies": {
    "@wordpress/block-editor": "^15.21.1",
    "@wordpress/blocks": "^15.21.1",
    "@wordpress/components": "^35.0.1",
    "@wordpress/core-data": "^7.48.1",
    "@wordpress/env": "^11.8.1",
    "@wordpress/i18n": "^6.21.1",
    "@wordpress/icons": "^14.0.1",
    "@wordpress/scripts": "^32.4.1",
    "orejime": "^3.2.0"
  }
}
